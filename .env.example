# =====================================================
# みせ勤 環境変数設定例
# .env.local にコピーして実際の値を設定してください
# 本番環境では環境変数として設定してください
# =====================================================

# データベース接続URL
DATABASE_URL="postgresql://user:password@localhost:5432/misekin?schema=public"

# Auth.js シークレット (openssl rand -base64 32 で生成)
AUTH_SECRET="your-secret-key-here"

# アプリURL
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# メール送信 (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="みせ勤 <noreply@your-domain.com>"

# 環境 (development | production | test)
NODE_ENV="development"

# シードデータ実行許可 (本番ではコメントアウトまたは false に設定)
# ALLOW_SEED="true"
