# サーバーの /opt/apps/misekin/.env にコピーして値を設定すること

# PostgreSQL パスワード（任意の強力なパスワードを設定）
POSTGRES_PASSWORD=change_this_strong_password

# Auth.js シークレット（openssl rand -base64 32 で生成）
AUTH_SECRET=change_this_secret

# アプリURL
NEXTAUTH_URL=https://dataraw.jp/dev/misekin

# メール送信 (Resend API キー。空でもメールなしで動作)
RESEND_API_KEY=
EMAIL_FROM=みせ勤 <noreply@dataraw.jp>
